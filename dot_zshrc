alias ls="eza --icons"
alias ll="eza -la --icons"
alias lt="eza --tree --icons"
alias la='eza --icons -A'
alias l='eza --icons -F'

# Tools
alias zl="zellij"
alias zellij='TERM=xterm-256color zellij'
alias shuf="gshuf"
alias codex='command codex --search --sandbox danger-full-access'

# Claude Code
export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
alias cc='claude -w --tmux'
alias notif='notify_command_done'

# Machine-local aliases (project-specific, not committed)
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# ===== FUNCTIONS =====
# Claude Code multi-account: runs claude with work credentials
claude-work() {
  CLAUDE_CONFIG_DIR="$HOME/.claude-work" claude -w --tmux "$@"
}

# Zellij dev environment
zdev() {
  if [[ -n "$ZELLIJ" ]]; then
    echo "Already inside Zellij. Exit first or open a new Ghostty window."
    return 1
  fi
  zellij --layout workspace
}

# Command notification wrapper: `notif long-command args...`
notify_command_done() {
    local ghostty_icon="file:///Applications/Ghostty.app"
    local start_time=$(date +%s)
    "$@"
    local exit_code=$?
    local end_time=$(date +%s)
    local duration=$((end_time - start_time))

    if [ $exit_code -eq 0 ]; then
        terminal-notifier \
            -title "Ghostty" \
            -message "Command completed successfully in ${duration}s" \
            -appIcon "$ghostty_icon" \
            -sound Pop
    else
        terminal-notifier \
            -title "Ghostty" \
            -message "Command failed (exit code ${exit_code}) after ${duration}s" \
            -appIcon "$ghostty_icon" \
            -sound Pop
    fi

    return $exit_code
}

notif_test_sounds() {
    local ghostty_icon="file:///Applications/Ghostty.app"
    local sounds=("$@")

    if [ ${#sounds[@]} -eq 0 ]; then
        sounds=(Glass Pop Funk Hero Frog Submarine Bottle Morse Tink)
    fi

    for sound in "${sounds[@]}"; do
        terminal-notifier \
            -title "Ghostty" \
            -message "Testing sound: ${sound}" \
            -appIcon "$ghostty_icon" \
            -sound "$sound"
        sleep 2
    done
}

# ===== PROMPT (must be last) =====
eval "$(starship init zsh)"

